          "schema_version": 0,
          "values": {
            "function_name": "atlas-ml-model-deployer",
            "description": "Deploys trained models to SageMaker endpoints. Triggered by S3 event when new model artifact lands.",
            "runtime": "python3.11",
            "handler": "deploy_handler.lambda_handler",
            "role": "aws_iam_role.lambda_model_deploy",
            "memory_size": 512,
            "timeout": 300,
            "s3_bucket": "atlas-ml-lambda-deployments-us-west-2",
            "s3_key": "model-deployer/v2.4.1/deploy_handler.zip",
            "environment": {
              "variables": {
                "MODEL_BUCKET": "atlas-ml-model-artifacts-prod-us-west-2",
                "SAGEMAKER_ROLE_ARN": "arn:aws:iam::891377225064:role/atlas-ml-sagemaker-execution-role",
                "ENDPOINT_PREFIX": "atlas-ml-prod",
                "LOG_LEVEL": "INFO",
                "SLACK_WEBHOOK_URL": "https://hooks.slack.com/services/T0XXXXXXX/B0XXXXXXX/xxxxxxxxxxxxxxxxxxx",
                "DEPLOY_NOTIFICATION_CHANNEL": "#ml-deployments"
              }
            },
            "dead_letter_config": null,
            "vpc_config": null,
            "tracing_config": {
              "mode": "PassThrough"
            },
            "tags": {
              "Name": "atlas-ml-model-deployer",
              "Team": "ml-engineering",
              "Version": "2.4.1",
              "TODO": "Add VPC config and DLQ - deprioritized for Q1 launch"
            }
          }
        },
