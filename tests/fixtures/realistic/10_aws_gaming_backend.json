        {
          "address": "aws_dynamodb_table.players",
          "mode": "managed",
          "type": "aws_dynamodb_table",
          "name": "players",
          "provider_name": "registry.terraform.io/hashicorp/aws",
          "schema_version": 1,
          "values": {
            "name": "stormforge-players",
            "billing_mode": "PAY_PER_REQUEST",
            "hash_key": "playerId",
            "attribute": [
              { "name": "playerId", "type": "S" },
              { "name": "username", "type": "S" },
              { "name": "elo", "type": "N" },
              { "name": "region", "type": "S" },
              { "name": "lastLogin", "type": "N" }
            ],
            "global_secondary_index": [
              {
                "name": "username-index",
                "hash_key": "username",
                "projection_type": "ALL"
              },
              {
                "name": "region-elo-index",
                "hash_key": "region",
                "range_key": "elo",
                "projection_type": "INCLUDE",
                "non_key_attributes": ["playerId", "username", "matchesPlayed", "winRate"]
              },
              {
                "name": "last-login-index",
                "hash_key": "region",
                "range_key": "lastLogin",
                "projection_type": "KEYS_ONLY"
              }
            ],
            "point_in_time_recovery": {
              "enabled": true
            },
            "server_side_encryption": {
              "enabled": true,
              "kms_key_arn": "arn:aws:kms:us-east-1:554433221100:key/mrk-game-data-key"
            },
            "tags": {
              "Name": "stormforge-players",
              "Team": "stormforge-backend",
              "DataType": "player-profiles"
            }
