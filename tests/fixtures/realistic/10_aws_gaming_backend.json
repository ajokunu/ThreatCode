        {
          "address": "aws_lambda_function.matchmaking",
          "mode": "managed",
          "type": "aws_lambda_function",
          "name": "matchmaking",
          "provider_name": "registry.terraform.io/hashicorp/aws",
          "schema_version": 0,
          "values": {
            "function_name": "stormforge-matchmaking",
            "description": "Handles player matchmaking — ELO-based matching, party grouping, region preference. Reads from Redis, writes match results to DynamoDB and SQS.",
            "runtime": "nodejs20.x",
            "handler": "matchmaking.handler",
            "role": "aws_iam_role.lambda_game_services",
            "memory_size": 1024,
            "timeout": 30,
            "s3_bucket": "stormforge-lambda-artifacts-prod",
            "s3_key": "matchmaking/v6.0.3/matchmaking.zip",
            "vpc_config": {
              "subnet_ids": ["aws_subnet.private_a", "aws_subnet.private_b"],
              "security_group_ids": ["aws_security_group.lambda_sg"]
            },
            "dead_letter_config": {
              "target_arn": "arn:aws:sqs:us-east-1:554433221100:stormforge-matchmaking-dlq"
            },
            "tracing_config": {
              "mode": "Active"
            },
            "environment": {
              "variables": {
                "REDIS_ENDPOINT": "stormforge-session-cache.xxxxx.use1.cache.amazonaws.com",
                "REDIS_PORT": "6379",
                "PLAYERS_TABLE": "stormforge-players",
                "MATCHES_TABLE": "stormforge-matches",
                "MATCHMAKING_QUEUE_URL": "https://sqs.us-east-1.amazonaws.com/554433221100/stormforge-matchmaking-queue",
                "ELO_RANGE_INITIAL": "100",
                "ELO_RANGE_MAX": "500",
                "ELO_EXPAND_INTERVAL_SEC": "10",
                "MAX_MATCH_WAIT_SEC": "120",
                "LOG_LEVEL": "info"
              }
            },
            "tags": {
              "Name": "stormforge-matchmaking",
              "Team": "stormforge-backend",
              "Service": "matchmaking",
              "Version": "6.0.3"
            }
          }
        },
